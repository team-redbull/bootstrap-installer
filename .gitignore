# macOS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
.env

# Terraform
.terraform/
*.tfstate.backup
tfplan
# Note: .terraform.lock.hcl is intentionally NOT ignored — commit it for reproducibility
# Note: aws/providers/ is intentionally NOT ignored — provider zips are pre-downloaded
#       (committed via Git LFS) so terraform init uses the local filesystem mirror.

# Terraform state in the aws working dir (the per-cluster states live in clusters/ and ARE tracked)
aws/terraform.tfstate

# Generated terraform.tfvars (written by bootstrap; may contain credentials)
aws/terraform.tfvars

# Binaries — utils_bin/ is intentionally NOT ignored — large files are tracked via Git LFS
# (.gitattributes: utils_bin/* filter=lfs diff=lfs merge=lfs -text)

# Sensitive config files — drop these in config/ but never commit them
config/pull-secret.json

# Cluster output lives in clusters/<name>/ (default work dir is inside this repo).
# Credentials are excluded; everything else (tfstate, ignition, configs) is tracked
# so clusters can be resumed from another machine after a git clone.
clusters/*/auth/          # kubeconfig + kubeadmin-password
clusters/*/*.log          # runtime logs (large, not useful to track)
clusters/*/install/       # openshift-install working dir (large, regeneratable)
