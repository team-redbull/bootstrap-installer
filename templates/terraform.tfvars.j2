######################################################################
# Auto-generated by ocp-bootstrap for cluster: {{ cluster_name }}
# Site: {{ site_name }} | Segment (subnet): {{ segment }}
# Generated: {{ timestamp }}
######################################################################

# AWS / Network
aws_region        = "{{ aws_region }}"
vpc_id            = "{{ vpc_id }}"
subnet_cidr       = "{{ machine_network_cidr }}"
availability_zone = "{{ availability_zone }}"
{% if route_table_id is defined and route_table_id -%}
route_table_id    = "{{ route_table_id }}"
{% endif -%}
rhcos_ami         = "{{ rhcos_ami }}"
ssh_key_name      = "{{ aws_ssh_key_name | default('') }}"
allowed_cidrs     = [{{ allowed_cidrs | default(['0.0.0.0/0']) | map('tojson') | join(', ') }}]

# Cluster Identity
cluster_id     = "{{ cluster_name }}"
base_domain    = "{{ base_domain }}"
cluster_domain = "{{ cluster_name }}.{{ base_domain }}"

# Ignition (rendered by openshift-install)
bootstrap_ignition_path     = "{{ ignition_dir }}/bootstrap.ign"
control_plane_ignition_path = "{{ ignition_dir }}/master.ign"
compute_ignition_path       = "{{ ignition_dir }}/worker.ign"
infra_ignition_path         = "{{ ignition_dir }}/worker.ign"

# Node IPs (offsets within the subnet; no VIPs — DNS round-robin)
bootstrap_ip      = "{{ bootstrap_ip }}"
control_plane_ips = [{{ control_plane_ips | map('tojson') | join(', ') }}]
infra_ips         = [{{ infra_ips | map('tojson') | join(', ') }}]
compute_ips       = [{{ compute_ips | map('tojson') | join(', ') }}]

# Instance sizing
bootstrap_instance_type     = "{{ bootstrap_instance_type | default('m5.large') }}"
bootstrap_disk_size         = {{ bootstrap_disk_size | default(120) }}

control_plane_count         = {{ control_plane_ips | length }}
control_plane_instance_type = "{{ control_plane_instance_type | default('m5.2xlarge') }}"
control_plane_disk_size     = {{ control_plane_disk_size | default(120) }}

infra_count                 = {{ infra_ips | length }}
infra_instance_type         = "{{ infra_instance_type | default('m5.2xlarge') }}"
infra_disk_size             = {{ infra_disk_size | default(120) }}

compute_count               = {{ compute_ips | length }}
compute_instance_type       = "{{ compute_instance_type | default('m5.xlarge') }}"
compute_disk_size           = {{ compute_disk_size | default(120) }}
