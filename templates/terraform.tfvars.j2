######################################################################
# Auto-generated by ocp-bootstrap for cluster: {{ cluster_name }}
# Site: {{ site_name }} | VLAN: {{ vlan_id }} | Segment: {{ segment }}
# Generated: {{ timestamp }}
######################################################################

# vSphere Infrastructure
vsphere_server            = "{{ vcenter }}"
vsphere_user              = "{{ vcenter_user }}"
vsphere_password          = "{{ vcenter_password }}"
vsphere_cluster           = "{{ vsphere_cluster }}"
vsphere_datacenter        = "{{ datacenter }}"
vsphere_datastore_cluster = "{{ vsphere_datastore_cluster }}"
vsphere_dvs_name          = "{{ vsphere_dvs_name }}"
vsphere_folder            = "{{ vsphere_folder }}"
vm_template               = "{{ vm_template }}"
vm_network                = "{{ vm_network }}"
vm_dns_addresses          = [{{ dns_servers | map('tojson') | join(', ') }}]
vsphere_required_tag_category = "{{ vsphere_required_tag_category | default('') }}"
vsphere_required_tag_name     = "{{ vsphere_required_tag_name | default('') }}"

# Cluster Identity
cluster_id     = "{{ cluster_name }}"
base_domain    = "{{ base_domain }}"
cluster_domain = "{{ cluster_name }}.{{ base_domain }}"

# Network
machine_cidr = "{{ machine_network_cidr }}"
gateway_ip   = "{{ gateway }}"

# Bootstrap
bootstrap_ignition_path = "{{ ignition_dir }}/bootstrap.ign"
bootstrap_ip            = "{{ bootstrap_ip }}"
bootstrap_disk_size     = {{ bootstrap_disk_size | default(120) }}

# Control Plane
control_plane_ignition_path = "{{ ignition_dir }}/master.ign"
control_plane_count         = {{ control_plane_ips | length }}
control_plane_ips           = [{{ control_plane_ips | map('tojson') | join(', ') }}]
control_plane_num_cpus      = {{ control_plane_num_cpus | default(4) }}
control_plane_memory        = {{ control_plane_memory | default(16384) }}
control_plane_disk_size     = {{ control_plane_disk_size | default(120) }}

# Compute (workers) — add compute_ip_offsets in the cluster config to provision these
compute_ignition_path = "{{ ignition_dir }}/worker.ign"
compute_count         = {{ compute_ips | length }}
compute_ips           = [{{ compute_ips | map('tojson') | join(', ') }}]
compute_num_cpus      = {{ compute_num_cpus | default(4) }}
compute_memory        = {{ compute_memory | default(8192) }}
compute_disk_size     = {{ compute_disk_size | default(120) }}

# Infra
infra_ignition_path = "{{ ignition_dir }}/worker.ign"
infra_count         = {{ infra_ips | length }}
infra_ips           = [{{ infra_ips | map('tojson') | join(', ') }}]
infra_num_cpus      = {{ infra_num_cpus | default(4) }}
infra_memory        = {{ infra_memory | default(16384) }}
infra_disk_size     = {{ infra_disk_size | default(120) }}
